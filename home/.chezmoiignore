# Ignorer la clé déchiffrée (créée par le script run_once_after)
.config/chezmoi/key.txt

# Ignorer les fichiers chiffrés tant que la clé age n'existe pas
# Un second `chezmoi apply` installera automatiquement les fichiers chiffrés
{{ if not (stat (joinPath .chezmoi.homeDir ".config/chezmoi/key.txt")) }}
.config/rclone/rclone.conf
.gitconfig
.kube/config
.config/k3s/**
.config/k3s
.ssh/id_rsa
printer_data/config/telegram.conf
{{ end }}

{{ if not (and (hasKey .my_hosts .chezmoi.hostname) (hasKey (index .my_hosts .chezmoi.hostname) "k3s")) }}
.config/k3s/**
.config/k3s
{{ end }}

{{ if not (or (eq .chezmoi.hostname "ender3pro") .is_wsl) }}
printer_data/**
printer_data
{{ end }}
