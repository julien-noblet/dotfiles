{{- if eq .chezmoi.os "windows" -}}
# Install nerdfonts
Write-Host "--- DÉMARRAGE INSTALLATION NERD FONTS ---" -ForegroundColor Yellow

Write-Host "Recherche de la version sur GitHub..."
try {
    $latestRelease = Invoke-RestMethod -Uri "https://api.github.com/repos/ryanoasis/nerd-fonts/releases/latest" -ErrorAction Stop
    Write-Host "Version : $($latestRelease.tag_name)" -ForegroundColor Green
} catch {
    Write-Host "ERREUR API GITHUB : $_" -ForegroundColor Red
    return
}

$globalBatchCommands = @("@echo off")

$count = 0
$totalFonts = "{{ len .fonts.NerdFonts }}"

{{ range .fonts.NerdFonts }}
    $font = "{{ . }}"
    $count++
    $percent = [math]::Floor(($count / $totalFonts) * 100)
    Write-Progress -Activity "Installation Nerd Fonts" -Status "Traitement de $font ($count/$totalFonts)" -PercentComplete $percent
    
    Write-Host "`n>> [$count/$totalFonts] Traitement de $font..." -ForegroundColor Cyan
    $url = "https://github.com/ryanoasis/nerd-fonts/releases/download/$($latestRelease.tag_name)/$font.zip"
    $output = Join-Path $env:TEMP "$font.zip"
    $fontTempDir = Join-Path $env:TEMP $font
    
    if (Test-Path $fontTempDir) { 
        Remove-Item -Path $fontTempDir -Recurse -Force -ErrorAction SilentlyContinue
    }
    
    Write-Host "   Téléchargement..." -NoNewline
    try {
        Invoke-WebRequest -Uri $url -OutFile $output -ErrorAction Stop
        Write-Host " OK ($((Get-Item $output).Length / 1MB -as [int]) MB)" -ForegroundColor Green
    } catch {
        Write-Host " ÉCHEC !" -ForegroundColor Red
        Write-Host "   $(_)" -ForegroundColor Gray
        continue
    }
    
    Write-Host "   Extraction..." -NoNewline
    try {
        Expand-Archive -Path $output -DestinationPath $fontTempDir -Force -ErrorAction Stop
        Write-Host " OK" -ForegroundColor Green
    } catch {
        Write-Host " ÉCHEC !" -ForegroundColor Red
        continue
    }
    
    $fontFiles = Get-ChildItem -Path $fontTempDir -Include *.ttf, *.otf -Recurse
    Write-Host "   $( $fontFiles.Count ) fichiers ajoutés à la file." -ForegroundColor Gray
    
    foreach ($fontFile in $fontFiles) {
        $destination = "$env:WINDIR\Fonts\$($fontFile.Name)"
        $globalBatchCommands += "copy /y `"$($fontFile.FullName)`" `"$destination`" >nul"
        
        $fontName = $fontFile.BaseName
        if ($fontFile.Extension -eq ".ttf") { $fontName += " (TrueType)" }
        elseif ($fontFile.Extension -eq ".otf") { $fontName += " (OpenType)" }
        
        $registryKey = "HKLM\SOFTWARE\Microsoft\Windows NT\CurrentVersion\Fonts"
        $globalBatchCommands += "reg add `"$registryKey`" /v `"$fontName`" /t REG_SZ /d `"$($fontFile.Name)`" /f >nul"
    }
    if (Test-Path $output) { Remove-Item -Path $output -Force }
{{- end -}}

Write-Progress -Activity "Installation Nerd Fonts" -Completed

# Dynamically find gsudo for administrative tasks
    $gsudoPath = $null
    $potentialPaths = @(
        "$env:ProgramFiles\gsudo\current\gsudo.exe",
        "$env:ProgramFiles\gsudo\gsudo.exe",
        "C:\Program Files\gsudo\2.6.1\gsudo.exe" # fragile but common path for gsudo
    )
    foreach ($p in $potentialPaths) {
        if ($p -and (Test-Path $p)) { $gsudoPath = $p; break }
    }
    if (-not $gsudoPath) { 
        $gsudoPath = (Get-Command gsudo -ErrorAction SilentlyContinue | Select-Object -ExpandProperty Source -ErrorAction SilentlyContinue)
    }
    if (-not $gsudoPath) { $gsudoPath = "gsudo" }

    # Check if we already have administrative privileges
    $currentPrincipal = New-Object Security.Principal.WindowsPrincipal([Security.Principal.WindowsIdentity]::GetCurrent())
    $isAlreadyAdmin = $currentPrincipal.IsInRole([Security.Principal.WindowsBuiltInRole]::Administrator)

    # Accumulate all administrative commands to run them in a single global elevated session
$globalBatchFilePath = Join-Path $env:TEMP "install_all_nerdfonts.cmd"
$globalBatchCommands = @("@echo off")

Write-Progress -Activity "Préparation des Nerd Fonts" -Completed

# Dynamically find gsudo for administrative tasks
$gsudoPath = $null
$potentialPaths = @(
    "$env:ProgramFiles\gsudo\current\gsudo.exe",
    "$env:ProgramFiles\gsudo\gsudo.exe",
    "C:\Program Files\gsudo\2.6.1\gsudo.exe" # fragile but common path for gsudo
)
foreach ($p in $potentialPaths) {
    if ($p -and (Test-Path $p)) { $gsudoPath = $p; break }
}
if (-not $gsudoPath) {
    $gsudoPath = (Get-Command gsudo -ErrorAction SilentlyContinue | Select-Object -ExpandProperty Source -ErrorAction SilentlyContinue)
}
if (-not $gsudoPath) { $gsudoPath = "gsudo" }

# Check if we already have administrative privileges
$currentPrincipal = New-Object Security.Principal.WindowsPrincipal([Security.Principal.WindowsIdentity]::GetCurrent())
$isAlreadyAdmin = $currentPrincipal.IsInRole([Security.Principal.WindowsBuiltInRole]::Administrator)

$globalBatchCommands | Out-File -FilePath $globalBatchFilePath -Encoding ascii

# Execute the global batch file with a single elevation request
Write-Host "--- DÉMARRAGE DE L'INSTALLATION ÉLEVÉE (UNE SEULE FOIS) ---"
if ($isAlreadyAdmin) {
    & cmd.exe /c $globalBatchFilePath
} else {
    Write-Host "Élévation requise pour installer TOUTES les polices en une seule fois..."
    & $gsudoPath cmd.exe /c $globalBatchFilePath
}

# Final cleanup
Write-Host "Nettoyage des fichiers temporaires..."
{{ range .fonts.NerdFonts }}
    if (Test-Path "$env:TEMP\{{ . }}") { Remove-Item -Path "$env:TEMP\{{ . }}" -Recurse -Force }
{{- end -}}
Remove-Item -Path $globalBatchFilePath -ErrorAction SilentlyContinue
Write-Host "--- INSTALLATION TERMINÉE ---"
{{- end -}}