{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "customManagers": [
    {
      "customType": "regex",
      "fileMatch": [
        "^home/\\.chezmoidata/asdf\\.yaml$"
      ],
      "matchStrings": [
        "name:\\s+(?<depName>[a-zA-Z0-9_-]+)\\n(?:(?:\\s+github:\\s+(?<packageName>[a-zA-Z0-9/_-]+))|(?:\\s+.*))?\\n(?:\\s+.*\\n)*\\s+versions:\\s+\\n\\s+-\\s+(?<currentValue>.*)"
      ],
      "datasourceTemplate": "github-releases",
      "versioningTemplate": "semver"
    }
  ],
  "packageRules": [
    {
      "matchUpdateTypes": [
        "pin",
        "digest"
      ],
      "enabled": false
    },
    {
      "matchPackageNames": [
        "golang/go"
      ],
      "versioning": "docker"
    }
  ]
}


